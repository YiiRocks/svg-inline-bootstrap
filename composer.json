{
    "name": "yiirocks/svg-inline-bootstrap",
    "description": "Inline Bootstrap Icons for Yii",
    "type": "library",
    "keywords": [
        "yii",
        "yii3",
        "extension",
        "bootstrap icons",
        "icon",
        "icons",
        "svg",
        "inline"
    ],
    "homepage": "https://www.yii.rocks/svg-inline-bootstrap/",
    "license": "BSD-3-Clause",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Mr.42",
            "homepage": "https://mr42.me/",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/YiiRocks/svg-inline-bootstrap/issues",
        "source": "https://github.com/YiiRocks/svg-inline-bootstrap/tree/master"
    },
    "require": {
        "php": ">=8.3",
        "twbs/bootstrap-icons": "^1.13",
        "yiirocks/svg-inline": "^1.0",
        "yiisoft/html": "^3.9 || ^4.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "@stable",
        "httpsoft/http-message": "^1.1",
        "infection/infection": "^0.34.0",
        "phpunit/phpunit": "@stable",
        "vimeo/psalm": "^6.0",
        "yiisoft/aliases": "^3.1",
        "yiisoft/config": "^1.6",
        "yiisoft/di": "*",
        "yiisoft/files": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "YiiRocks\\SvgInline\\Bootstrap\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YiiRocks\\SvgInline\\Bootstrap\\tests\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "scripts": {
        "php-cs-fixer": "@php vendor/bin/php-cs-fixer fix",
        "phpunit": "@php vendor/bin/phpunit",
        "psalm": "@php vendor/bin/psalm",
        "infection": "@php vendor/bin/infection --configuration=infection.json --min-msi=100 --min-covered-msi=100"
    },
    "scripts-descriptions": {
        "php-cs-fixer": "Cleans to code with PHP Coding Standards Fixer.",
        "phpunit": "PHPUnit - programmer-oriented testing framework.",
        "psalm": "Psalm - static analysis tool for finding errors in PHP applications.",
        "infection": "Infection - PHP Mutation Testing Framework."
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        },
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php",
            "di": "di.php"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "yiisoft/config": true
        }
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/YiiRocks"
        }
    ]
}
